# Copy this file to .env and fill in what you need.
# Nothing here is required to run LegalGPT locally with free/local defaults
# (embeddings = sentence-transformers, LLM = Ollama).

ENVIRONMENT=development
DEBUG=true

# Comma-separated list is not used; edit config.py default list or add
# CORS_ORIGINS=["http://localhost:5173"] as JSON if you need to override.

# --- Embeddings ---
# local = sentence-transformers (no API key, runs on CPU)
# openai = requires OPENAI_API_KEY
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# --- LLM provider ---
# ollama (local/free) | openai | anthropic
LLM_PROVIDER=ollama

# Ollama (only used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (only used when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Anthropic (only used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-sonnet-4-6
